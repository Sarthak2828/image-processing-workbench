{
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "image_operations.py",
        "index.html"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
